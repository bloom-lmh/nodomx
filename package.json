{
  "name": "nodom3",
  "version": "0.2.3",
  "private": false,
  "main": "index.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node ./tests/composition.smoke.mjs",
    "test:smoke": "node ./tests/composition.smoke.mjs",
    "test:nd": "npm run test -w @nodomx/nd-compiler",
    "test:nd:rollup": "npm run test -w @nodomx/rollup-plugin-nd",
    "test:dev-server": "npm run test -w @nodomx/rollup-plugin-dev-server",
    "test:create": "npm run test -w create-nodomx",
    "test:vscode": "npm run test -w nodomx-nd-vscode",
    "test:all": "npm run test && npm run test:nd && npm run test:nd:rollup && npm run test:dev-server && npm run test:create && npm run test:vscode",
    "build": "rollup -c rollup.config.mjs",
    "build:nd": "npm run build -w @nodomx/nd-compiler",
    "build:nd:rollup": "npm run build -w @nodomx/rollup-plugin-nd",
    "build:dev-server": "npm run build -w @nodomx/rollup-plugin-dev-server",
    "build:create": "npm run build -w create-nodomx",
    "build:vscode": "npm run build -w nodomx-nd-vscode",
    "build:all": "npm run build && npm run build:nd && npm run build:nd:rollup && npm run build:dev-server && npm run build:create && npm run build:vscode",
    "watch": "rollup -c rollup.config.mjs -w",
    "watch:nd": "node ./packages/nd-compiler/bin/ndc.mjs ./examples --watch",
    "compile:nd": "node ./packages/nd-compiler/bin/ndc.mjs",
    "package:extension": "npm run package -w nodomx-nd-vscode"
  },
  "author": "weblabsw",
  "license": "MIT",
  "unpkg": "dist/nodom.esm.min.js",
  "module": "dist/nodom.esm.min.js",
  "types": "dist/types/index.d.ts",
  "browser": "dist/nodom.global.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodomjs/nodom3"
  },
  "keywords": [
    "nodom",
    "typescript",
    "javascript",
    "mvvm",
    "web"
  ],
  "bugs": {
    "url": "https://github.com/nodomjs/nodom3/issues"
  },
  "homepage": "https://github.com/nodomjs/nodom3",
  "description": "nodom是一款基于数据驱动的web mvvm框架,用于搭建单页应用(SPA)",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.2",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^24.1.0",
    "jsdom": "^29.0.1",
    "rollup": "^3.26.0",
    "rollup-plugin-typescript2": "^0.35.0"
  }
}
