{
  "compilerOptions": {
    "strict": false,
    "module": "esnext",
    "target": "ES2015",
    "lib": [
      "es5",
      "es6",
      "dom",
      "ES2017"
    ],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "sourceMap": true,
    "moduleResolution": "node",
    "declaration": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nodomx/reactivity": [
        "../reactivity/src/index.ts"
      ],
      "@nodomx/runtime-core": [
        "../runtime-core/src/index.ts"
      ]
    }
  },
  "include": [
    "src/index.ts"
  ]
}
